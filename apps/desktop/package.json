{
  "name": "@excel-analyzer/desktop",
  "version": "1.0.0",
  "description": "Analizador de documentos empresariales con IA",
  "author": "Excel Analyzer",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint src electron --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@excel-analyzer/shared-types": "*",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@tanstack/react-query": "^5.40.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron-log": "^5.1.0",
    "lucide-react": "^0.395.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "tailwind-merge": "^2.3.0",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.excelanalyzer.app",
    "productName": "Excel Analyzer",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "resources/excel-analyzer-backend/",
        "to": "backend/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/keytar/**/*"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "7zip-bin": "^5.2.0",
    "autoprefixer": "^10.4.0",
    "electron": "32.3.3",
    "electron-builder": "^24.13.0",
    "eslint": "^9.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^1.6.0"
  }
}
